    "helmet": "^8.1.0",
    "pg": "^8.11.5",
    "pg-format": "^1.0.4",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.12.13",
    "@types/pg": "^8.11.2",
    "@types/pg-format": "^1.0.5",
    "tsc-alias": "^1.8.10",
